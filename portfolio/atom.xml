---
layout: feed
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">

	<title>Portfolio</title>
	<link href="http://naedortega.github.io/portfolio/atom.xml" rel="self"/>
	<link href="http://naedortega.github.io/portfolio"/>
	<updated>{{ site.time | date_to_xmlschema }}</updated>
	<id>http://naedortega.github.io/portfolio</id>
	<author>
		<name>Naed Ortega</name>
		<email>NaedOrtega@ciencias.unam.mx</email>
	</author>

	{% for post in site.posts %}
		<entry>
			<title>{{ post.title }}</title>
			<link href="http://naedortega.github.io{{ post.url }}"/>
			<updated>{{ post.date | date_to_xmlschema }}</updated>
			<id>http://naedortega.github.io{{ post.id }}</id>
			<content type="html">{{ post.content | xml_escape }}</content>
		</entry>
	{% endfor %}

</feed>
